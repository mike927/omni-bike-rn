{
  "name": "omni-bike-rn",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "ios:sim": "expo run:ios",
    "db:generate": "drizzle-kit generate && prettier --single-quote --write drizzle/migrations.js",
    "db:check": "drizzle-kit check",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "ci:gate": "npm run lint && npm run typecheck && npm test -- --ci --runInBand",
    "build:smoke": "expo prebuild --clean && expo export -p ios -p android",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "drizzle-orm": "^0.45.2",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "expo-file-system": "~19.0.21",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/react-native": "^3.0.9",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "^55.0.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
